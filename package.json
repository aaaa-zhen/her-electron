{
  "name": "her",
  "version": "1.10.0",
  "description": "Her — AI companion desktop app",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "start:relay": "node remote-server/server.js",
    "build": "electron-builder",
    "build:mac": "electron-builder --mac",
    "build:win": "electron-builder --win"
  },
  "build": {
    "appId": "com.her.desktop",
    "productName": "Her",
    "directories": {
      "output": "dist"
    },
    "files": [
      "main.js",
      "src/**/*",
      "node_modules/**/*"
    ],
    "protocols": [
      {
        "name": "Her URL",
        "schemes": [
          "her"
        ]
      }
    ],
    "mac": {
      "category": "public.app-category.productivity",
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "build/icon.icns",
      "identity": null
    },
    "win": {
      "target": [
        "nsis"
      ],
      "icon": "build/icon.png"
    }
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "archiver": "^7.0.1",
    "color-name": "^2.1.0",
    "docx": "^9.6.1",
    "dotenv": "^17.3.1",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "multer": "^2.0.2",
    "node-cron": "^4.2.1",
    "pdf-lib": "^1.17.1",
    "pdf-parse": "^2.4.5",
    "pptxgenjs": "^4.0.1",
    "qrcode": "^1.5.4",
    "sharp": "^0.34.5",
    "tesseract.js": "^7.0.0",
    "unzipper": "^0.12.3",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "electron": "^35.0.0",
    "electron-builder": "^25.1.8"
  }
}
